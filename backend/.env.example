# Field Sales CRM — Environment Configuration
# Copy this file to .env and fill in your values

# ============ OpenAI API ============
OPEN_API_KEY=sk-your-openai-api-key-here

# ============ Database ============
# Path to SQLite database file (Windows path)
DATABASE_PATH=C:/ventas/crm.db

# ============ Server ============
HOST=0.0.0.0
PORT=8000
# Set DEBUG=false in production
DEBUG=false

# ============ Audio Storage ============
# Where to store uploaded audio files
AUDIO_STORAGE_PATH=C:/ventas/audios

# ============ AI Models ============
WHISPER_MODEL=whisper-1
GPT_MODEL=gpt-4o-mini

# ============ App Settings ============
# Language for transcription (es = Spanish, en = English, auto = auto-detect)
TRANSCRIPTION_LANGUAGE=auto

# Maximum audio file size in MB
MAX_AUDIO_SIZE_MB=50

# ============ Security ============
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_generate_with_secrets_token_hex_32

# JWT token lifetime in minutes (43200 = 30 days, suitable for mobile apps)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ============ CORS ============
# JSON array of allowed origins for browser-based clients (e.g. Streamlit dashboard)
# Mobile apps (React Native) are not subject to CORS — include only browser clients here
CORS_ORIGINS=["http://localhost:8501"]
# Production example:
# CORS_ORIGINS=["https://ventas.your-tunnel.com"]
