# Field Sales CRM — Environment Configuration
# Copy this file to .env and fill in your values

# ============ OpenAI API ============
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============ Database ============
# Path to SQLite database file (Windows path)
DATABASE_PATH=C:/ventas/crm.db

# ============ Server ============
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ============ Audio Storage ============
# Where to store uploaded audio files
AUDIO_STORAGE_PATH=C:/ventas/audios

# ============ AI Models ============
WHISPER_MODEL=whisper-1
GPT_MODEL=gpt-4o-mini

# ============ App Settings ============
# Language for transcription (es = Spanish, en = English, auto = auto-detect)
TRANSCRIPTION_LANGUAGE=auto

# Maximum audio file size in MB
MAX_AUDIO_SIZE_MB=50

# ============ Security ============
# Secret key for JWT tokens (change this!)
SECRET_KEY=change-this-to-a-random-string-in-production
API_KEY_HEADER=X-API-Key
